#!/usr/bin/env bash

log() {
    echo "$(date +"[%Y-%m-%d %T,%3N]") <docker-entrypoint> $*"
}

set_java_home() {
    local java_bin
    java_bin=$(readlink -f /usr/bin/java 2>/dev/null)
    if [ -n "${java_bin}" ]; then
        JAVA_HOME="${java_bin%/bin/java}"
    fi
    if [ ! -d "${JAVA_HOME}" ]; then
        local arch
        arch=$(dpkg --print-architecture 2>/dev/null)
        # Try Temurin first (installed by docker-build.sh), then fall back to openjdk
        JAVA_HOME=$(ls -d /usr/lib/jvm/temurin-*-jdk-${arch} 2>/dev/null | sort -V | tail -1)
        if [ ! -d "${JAVA_HOME}" ]; then
            JAVA_HOME=/usr/lib/jvm/java-21-openjdk-${arch}
        fi
    fi
}

instPkg() {
    for pkg in $*; do
        if [ $(dpkg-query -W -f='${Status}' "${pkg}" 2>/dev/null | grep -c "ok installed") -eq 0 ];
        then
            apt-get -qy install "${pkg}";
        fi
    done
}

# Validate that any included hotfixes have been applied
validate() (
  shopt -s nullglob
  for i in /usr/local/unifi/hotfixes/*-validate.md5sum; do
    md5sum -c "$i" > /dev/null 2>&1 || return 1
    echo "Hotfix validated: $(basename ${i::-16})"
  done
)
